# portal backend
PORTAL_BACKEND_HOST=
# Public scheme of the portal. Decides whether the backend generates http:// or
# https:// URLs (workflow metadata, MinIO presigned links, CORS origins).
# Behind the platform gateway this must match however the gateway is reached from
# a browser — including the case where TLS is terminated by a load balancer in
# front of the gateway (then SSL=true even though the gateway itself speaks HTTP).
SSL=false
DIGITALTWINS_API_BASE_URL=http://digitaltwins-api
DIGITALTWINS_API_PORT=8000
MINIO_PORT=
MINIO_SERVER_ACCESS_KEY=
MINIO_SERVER_SECRET_KEY=
# MinIO Console public URL (proxied by nginx at /minio-console/)
# HTTP  example: http://130.216.216.243/minio-console
# HTTPS example: https://portal.example.com/minio-console
# No trailing slash.
MINIO_BROWSER_REDIRECT_URL=


# keycloak configuration
PORTAL_KEYCLOAK_BASE_URL=https://<ip_address>:port
KEYCLOAK_REALM=digitaltwins
KEYCLOAK_CLIENT_ID=api
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_VERIFY_SSL=false
KEYCLOAK_CA_CERT=

PROJECT_NAME=digitaltwins-platform